{
  "name": "spr-viewer-vsc",
  "displayName": "SPR Viewer",
  "version": "1.0.1",
  "description": "",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.120.0"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "spr.view",
        "displayName": "SPR Viewer",
        "selector": [
          {
            "filenamePattern": "*.spr"
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trhh0vn0/spr-viewer-vsc.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/trhh0vn0/spr-viewer-vsc/issues"
  },
  "homepage": "https://github.com/trhh0vn0/spr-viewer-vsc",
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
